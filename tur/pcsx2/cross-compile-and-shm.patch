diff --git a/common/Linux/LnxHostSys.cpp b/common/Linux/LnxHostSys.cpp
index 54a8e2f..d6abcf5 100644
--- a/common/Linux/LnxHostSys.cpp
+++ b/common/Linux/LnxHostSys.cpp
@@ -1,3 +1,41 @@
+#if defined(__ANDROID__)
+#include <fcntl.h>
+#include <sys/stat.h>
+#include <unistd.h>
+#include <cstdio>
+#include <cstring>
+#include <cerrno>
+
+static inline int shm_unlink(const char *name) {
+	while (name[0] == '/') ++name;
+	if (name[0] == '\0') {
+		errno = EINVAL;
+		return -1;
+	}
+	char fname[256];
+	snprintf(fname, sizeof(fname), "/data/data/com.termux/files/usr/tmp/%s", name);
+	return unlink(fname);
+}
+
+static inline int shm_open(const char *name, int oflag, mode_t mode) {
+	while (name[0] == '/') ++name;
+	if (name[0] == '\0') {
+		errno = EINVAL;
+		return -1;
+	}
+	char fname[256];
+	snprintf(fname, sizeof(fname), "/data/data/com.termux/files/usr/tmp/%s", name);
+	int fd = open(fname, oflag, mode);
+	if (fd != -1) {
+		int flags = fcntl(fd, F_GETFD, 0);
+		if (flags != -1) {
+			fcntl(fd, F_SETFD, flags | FD_CLOEXEC);
+		}
+	}
+	return fd;
+}
+#endif
+
