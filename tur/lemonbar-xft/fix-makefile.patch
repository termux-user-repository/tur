--- a/Makefile
+++ b/Makefile
@@ -6,8 +6,12 @@ ifneq "$(GIT_DESC)" ""
 	VERSION=$(GIT_DESC)
 endif
 
+CFLAGS ?=
+CPPFLAGS ?=
+LDFLAGS ?=
+
 CC	?= gcc
-CFLAGS += -Wall -std=c99 -Os -DVERSION="\"$(VERSION)\"" -I/usr/include/freetype2
+CFLAGS += -Wall -std=c99 -Os -DVERSION="\"$(VERSION)\"" -I@TERMUX_PREFIX@/include/freetype2 $(CPPFLAGS)
 LDFLAGS += -lxcb -lxcb-xinerama -lxcb-randr -lX11 -lX11-xcb -lXft -lfreetype -lz -lfontconfig
