+#if MUST_INIT_X11
+static int X11ErrorHandler([[maybe_unused]] Display* display, XErrorEvent* error)
+{
+	// Ignore BadWindow errors, which can happen during shutdown if SDL is still processing events.
+	// This prevents a crash message reported on some X11/SDL2 configurations.
+	if (error->error_code == BadWindow)
+		return 0;
+	return 0;
+}
+#endif
