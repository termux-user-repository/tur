-        sys_data.arm = strstr(utsinfo.machine, "aarch") ? true : false;
+        sys_data.arm = strstr(utsinfo.machine, "aarch") || strstr(utsinfo.machine, "arm") ? true : false;
         sys_data.version = string(utsinfo.sysname) + " " + utsinfo.release + " " + utsinfo.version;
