     if (file.is_open()) {
         while (getline(file, line)) {
-            if (line.compare(0, 10, "model name") == 0 || line.compare(0, 9, "Processor") == 0) {
+            if (line.compare(0, 8, "Hardware") == 0 || line.compare(0, 9, "Processor") == 0 || line.compare(0, 10, "model name") == 0) {
                 auto pos = line.find(':');
                 if (pos != string::npos) {
                     proc_name = line.substr(pos + 1);
@@ -50,47 +59,30 @@ bool get_cpu_freq(uint32_t &cpu_freq) {
