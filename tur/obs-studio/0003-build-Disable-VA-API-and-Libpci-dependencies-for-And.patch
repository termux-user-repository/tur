 using namespace std;
 
 namespace {
 
-GoLiveApi::Gpu get_primary_gpu() {
+// DYNAMIC GPU QUERY: Ask OBS what GPU is currently rendering!
+std::optional<std::vector<GoLiveApi::Gpu>> system_gpu_data() {
+    std::vector<GoLiveApi::Gpu> adapter_info;
     GoLiveApi::Gpu gpu{};
-    gpu.vendor_id=0x5143;
-    gpu.device_id = 0x0000;          // Vulkan info
-    gpu.model = "Turnip Adreno (TM) 650";
-    gpu.driver_version = "Mesa 25.3.3";
-    gpu.dedicated_video_memory = 0;
-    gpu.shared_system_memory = 7610ULL * 1024 * 1024;
-    return gpu;
+
+    // Enter the OBS graphics context to query the live driver
+    obs_enter_graphics();
+    const char *renderer = gs_get_renderer();
+    const char *driver_ver = gs_get_driver_version();
+    gpu.dedicated_video_memory = gs_get_gpu_dmem() * 1024;
+    gpu.shared_system_memory = gs_get_gpu_smem() * 1024;
+    obs_leave_graphics();
+
+    gpu.vendor_id = 0; // PCI bus scanning is blocked by Android SELinux
+    gpu.device_id = 0;
+    gpu.model = renderer ? renderer : "Unknown Android GPU";
+    gpu.driver_version = driver_ver ? driver_ver : "Unknown Mesa/Driver";
+
+    adapter_info.push_back(gpu);
+    return adapter_info;
 }
 
 bool get_cpu_name(optional<string> &proc_name) {
     ifstream file("/proc/cpuinfo");
     string line;
-    proc_name = "Unknown";
