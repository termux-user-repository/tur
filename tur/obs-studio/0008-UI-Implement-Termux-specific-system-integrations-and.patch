+static void TermuxOpenUrl(const QUrl &url) {
+    // Convert the Qt URL into a standard string
+    std::string urlStr = url.toString().toStdString();
+
+    // Build a raw shell command using our custom script
+    std::string cmd = "xdg-open \"" + urlStr + "\" &";
+
+    // Force the OS to execute it directly, bypassing Qt's D-Bus
+    system(cmd.c_str());
+}
