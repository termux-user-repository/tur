@@ -27,6 +30,21 @@
 
 #define YOUTUBE_CHAT_DOCK_NAME "ytChat"
 
+static std::string GetTermuxYTKey(int line_number) {
+    const char* home = getenv("HOME");
+    if (home) {
+        std::ifstream in(std::string(home) + "/.config/obs-studio/youtube_keys.txt");
+        std::string line;
+        for(int i = 0; i < line_number; ++i) {
+            std::getline(in, line);
+        }
+        // Trim whitespace
+        line.erase(line.find_last_not_of(" \n\r\t") + 1);
+        if (!line.empty()) return line;
+    }
+    return "bring_your_own_key";
+}
