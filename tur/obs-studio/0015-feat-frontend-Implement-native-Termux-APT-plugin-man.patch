+PluginManagerWindow::~PluginManagerWindow() { delete ui; }
+
+bool PluginManagerWindow::hasUnsavedChanges() const {
+	if (modules_.size() != original_modules_.size()) return true;
+	for (size_t i = 0; i < modules_.size(); ++i) {
+		if (modules_[i].enabled != original_modules_[i].enabled) return true;
+	}
+	return false;
+}
+
+void PluginManagerWindow::onApplyClicked() { accept(); }
+
+void PluginManagerWindow::onCancelClicked() {
+	if (hasUnsavedChanges()) {
+		QMessageBox::StandardButton btn = QMessageBox::warning(this, "Unsaved Changes",
+			"You have unsaved changes to your plugins.\nAre you sure you want to discard them?",
+			QMessageBox::Yes | QMessageBox::No);
+		if (btn == QMessageBox::No) return;
+	}
+	reject();
+}
+
+void PluginManagerWindow::closeEvent(QCloseEvent *event) {
+	if (hasUnsavedChanges()) {
+		QMessageBox::StandardButton btn = QMessageBox::warning(this, "Unsaved Changes",
+			"You have unsaved changes to your plugins.\nAre you sure you want to discard them?",
+			QMessageBox::Yes | QMessageBox::No);
+		if (btn == QMessageBox::No) {
+			event->ignore();
+			return;
+		}
+	}
+	event->accept();
+	reject();
+}
+
+void PluginManagerWindow::clearLayout(QLayout* layout) {
+	if (!layout) return;
+	QLayoutItem *item;
+	while ((item = layout->takeAt(0)) != nullptr) {
+		if (QWidget *w = item->widget()) { w->deleteLater(); }
+		delete item;
+	}
+}
+
+void PluginManagerWindow::populatePlugins()
+{
+	storeEmptyLabel->setText("Scanning local packages... UI will freeze momentarily.");
+	manageEmptyLabel->setText("Scanning local packages... UI will freeze momentarily.");
+	storeEmptyLabel->setVisible(true);
+	manageEmptyLabel->setVisible(true);
+	QCoreApplication::processEvents();
+
+	cachedPlugins.clear();
+
+	QProcess upgProc(this);
+	upgProc.start("apt", QStringList() << "list" << "--upgradable");
+	upgProc.waitForFinished();
+	QString upgOutput = upgProc.readAllStandardOutput();
+
+	QProcess searchProcess(this);
+	searchProcess.start("apt-cache", QStringList() << "search" << "^obs-");
+	searchProcess.waitForFinished();
+	QStringList lines = QString(searchProcess.readAllStandardOutput()).split('\n', Qt::SkipEmptyParts);
+
+	QRegularExpression xNameRegex("^X-Display-Name:\\s*(.*)$", QRegularExpression::MultilineOption);
+	QRegularExpression descRegex("^Description:\\s*(.*)$", QRegularExpression::MultilineOption);
+	QRegularExpression versionRegex("^Version:\\s*(.*)$", QRegularExpression::MultilineOption);
+	QRegularExpression homepageRegex("^Homepage:\\s*(.*)$", QRegularExpression::MultilineOption);
+	QRegularExpression sizeRegex("^Size:\\s*(\\d+)$", QRegularExpression::MultilineOption);
+	QRegularExpression installedRegex("^Installed-Size:\\s*(\\d+)$", QRegularExpression::MultilineOption);
+
+	for (const QString &line : lines) {
+		auto dashIndex = line.indexOf(" - ");
+		if (dashIndex == -1) continue;
+
+		QString pkgName = line.left(dashIndex).trimmed();
+		if (pkgName == "obs-studio" || pkgName == "obs-studio-dev") continue;
+
+		QProcess showProc(this);
+		showProc.start("apt-cache", QStringList() << "show" << pkgName);
+		showProc.waitForFinished();
+		QString fullData = showProc.readAllStandardOutput();
+
+		qsizetype firstRecordEnd = fullData.indexOf("\n\n");
+		if (firstRecordEnd != -1) {
+			fullData = fullData.left(firstRecordEnd);
+		}
+
+		QRegularExpressionMatch match;
+		FetchedPluginData data;
+		data.pkgName = pkgName;
+		data.version = (match = versionRegex.match(fullData)).hasMatch() ? match.captured(1).trimmed() : "Unknown";
+		data.homepage = (match = homepageRegex.match(fullData)).hasMatch() ? match.captured(1).trimmed() : "Unknown";
+		data.shortDesc = (match = descRegex.match(fullData)).hasMatch() ? match.captured(1).trimmed() : "No description available.";
+
+		if ((match = xNameRegex.match(fullData)).hasMatch()) {
+			data.displayName = match.captured(1).trimmed();
+		} else {
+			QString fallbackName = pkgName;
+			if (fallbackName.startsWith("obs-")) {
+				fallbackName.remove(0, 4);
+				if (fallbackName.endsWith("-source")) fallbackName.chop(7);
+				data.displayName = fallbackName;
+			}
+		}
+
+		if ((match = sizeRegex.match(fullData)).hasMatch()) {
+			double mb = match.captured(1).toDouble() / 1048576.0;
+			data.downloadSize = (mb >= 1.0) ? QString::number(mb, 'f', 1) + " MB" : QString::number(match.captured(1).toDouble() / 1024.0, 'f', 0) + " KB";
+		} else {
+			data.downloadSize = "Unknown";
+		}
+
+		if ((match = installedRegex.match(fullData)).hasMatch()) {
+			double mb = match.captured(1).toDouble() / 1024.0;
+			data.installedSize = (mb >= 1.0) ? QString::number(mb, 'f', 1) + " MB" : match.captured(1).trimmed() + " KB";
+		} else {
+			data.installedSize = "Unknown";
+		}
+
+		int descIndex = fullData.indexOf(descRegex);
+		if (descIndex != -1) {
+			int startOfLongDesc = fullData.indexOf('\n', descIndex) + 1;
+			int endOfLongDesc = fullData.indexOf(QRegularExpression("\n[A-Z][a-zA-Z0-9-]*:"), startOfLongDesc);
+			if (endOfLongDesc == -1) endOfLongDesc = fullData.length();
+
+			QString rawLongDesc = fullData.mid(startOfLongDesc, endOfLongDesc - startOfLongDesc).trimmed();
+			rawLongDesc.replace("\n .", "\n\n");
+			rawLongDesc.replace("\n ", "\n");
+			data.fullText = rawLongDesc;
+		}
+
+		QProcess checkProc(this);
+		checkProc.start("dpkg-query", QStringList() << "-W" << "-f=${Status}" << pkgName);
+		checkProc.waitForFinished();
+		data.isInstalled = QString(checkProc.readAllStandardOutput()).contains("installed");
+		data.hasUpdate = upgOutput.contains(pkgName + "/");
+
+		data.moduleName = "";
+		if (data.isInstalled) {
+			QProcess fileProc(this);
+			fileProc.start("dpkg", QStringList() << "-L" << pkgName);
+			fileProc.waitForFinished();
+			for (const QString& f : QString(fileProc.readAllStandardOutput()).split('\n')) {
+				if (f.endsWith(".so")) {
+					data.moduleName = f.mid(f.lastIndexOf('/') + 1);
+					data.moduleName.replace(".so", "");
+					break;
+				}
+			}
+		}
+
+		cachedPlugins.append(data);
+	}
+}
+
+void PluginManagerWindow::reloadUI() {
+	storeList->clear();
+	manageList->clear();
+	allUiRows.clear();
+
+	for (int i = 0; i < cachedPlugins.size(); ++i) {
+		FetchedPluginData &data = cachedPlugins[i];
+
+		idian::Row *mainRow = new idian::Row();
+
+		// Main Typography Hierarchy
+		mainRow->setTitle(QString("<span style='font-size: 13pt; font-weight: 800; color: #ffffff;'>%1</span>").arg(data.displayName));
+		mainRow->setDescription(QString("<span style='font-size: 10pt; color: #aaaaaa;'>%1</span>").arg(data.shortDesc));
+
+		DetailsRow *detailsRow = new DetailsRow();
+		detailsRow->setVisible(false);
+
+		// HTML Table for rigid alignment of metadata
+		QString detailsText = QString(
+			"<table width='100%' style='margin-bottom: 12px; margin-top: 4px;'>"
+			"<tr>"
+			"<td width='33%'><span style='color: #4CAF50;'><b>Version:</b> %1</span></td>"
+			"<td width='33%'><span style='color: #2196F3;'><b>Download:</b> %2</span></td>"
+			"<td width='33%'><span style='color: #FF9800;'><b>Installed:</b> %3</span></td>"
+			"</tr>"
+			"</table>"
+		).arg(data.version, data.downloadSize, data.installedSize);
+
+		if (data.homepage != "Unknown") {
+			detailsText += QString("<span style='font-size: 10pt;'><b>Homepage:</b> <a href='%1' style='color: #8bb4f7; text-decoration: none;'>%1</a></span><br><br>").arg(data.homepage);
+		}
+
+		if (!data.fullText.isEmpty()) {
+			QString cleanDesc = data.fullText;
+			cleanDesc.replace("\n", "<br>");
+			detailsText += QString("<div style='color: #dddddd; line-height: 1.5; font-size: 10.5pt;'>%1</div>").arg(cleanDesc);
+		}
+
+		detailsRow->contentLabel->setText(detailsText);
+		detailsRow->setAccessibleName("Loaded");
+
+		QWidget *suffixContainer = new QWidget();
+		QHBoxLayout *suffixLayout = new QHBoxLayout(suffixContainer);
+		suffixLayout->setContentsMargins(0, 0, 0, 0);
+		suffixLayout->setSpacing(15);
+
+		QPushButton *detailsBtn = new QPushButton("");
+		detailsBtn->setFixedSize(30, 30);
+		detailsBtn->setIcon(QIcon(":/icons/chevron-down.svg"));
+		detailsBtn->setIconSize(QSize(24, 24));
+		detailsBtn->setStyleSheet("background: transparent; border: none;");
+		detailsBtn->setAutoDefault(false);
+
+		if (!data.isInstalled) {
+			QPushButton *installBtn = new QPushButton("Install");
+			installBtn->setFixedSize(80, 32);
+			installBtn->setStyleSheet("background-color: #2b2b2b; border-radius: 4px; color: white; font-weight: bold; border: 1px solid #555;");
+			installBtn->setAutoDefault(false);
+
+			suffixLayout->addWidget(installBtn);
+			suffixLayout->addWidget(detailsBtn);
+			mainRow->setSuffix(suffixContainer);
+
+			storeList->addRow(mainRow);
+			storeList->addRow(detailsRow);
+
+			connect(installBtn, &QPushButton::clicked, this, [this, installBtn, i]() {
+				installBtn->setText("Installing...");
+				installBtn->setEnabled(false);
+				QCoreApplication::processEvents();
+
+				QProcess dryRunProc;
+				dryRunProc.start("apt", QStringList() << "-s" << "install" << cachedPlugins[i].pkgName);
+				dryRunProc.waitForFinished();
+
+				if (dryRunProc.exitCode() != 0) {
+					installBtn->setText("Error");
+					installBtn->setEnabled(true);
+					return;
+				}
+
+				QString output = dryRunProc.readAllStandardOutput();
+
+				if (output.contains("The following additional packages will be installed:")) {
+					QString depsString = "";
+					QStringList lines = output.split('\n');
+					bool inDepList = false;
+
+					for (const QString& line : lines) {
+						if (line.startsWith("The following additional packages will be installed:")) {
+							inDepList = true;
+							continue;
+						}
+						if (inDepList) {
+							if (line.startsWith("  ")) {
+								depsString += line.trimmed() + " ";
+							} else if (!line.trimmed().isEmpty()) {
+								break;
+							}
+						}
+					}
+
+					depsString = depsString.trimmed().replace(" ", ", ");
+
+					QString diskSpace = "Significant additional disk space will be used.";
+					qsizetype spaceIdx = output.indexOf("After this operation, ");
+					if (spaceIdx != -1) {
+						qsizetype endIdx = output.indexOf("used.", spaceIdx);
+						if (endIdx != -1) {
+							diskSpace = output.mid(spaceIdx, endIdx - spaceIdx + 5).trimmed();
+						}
+					}
+
+					QMessageBox::StandardButton reply = QMessageBox::question(this,
+						"Dependencies Required",
+						QString("To install this plugin, the following additional packages must also be installed:\n\n"
+							"<b>%1</b>\n\n"
+							"%2\n\n"
+							"Do you want to proceed?").arg(depsString, diskSpace),
+						QMessageBox::Yes | QMessageBox::No);
+
+					if (reply == QMessageBox::No) {
+						installBtn->setText("Install");
+						installBtn->setEnabled(true);
+						return;
+					}
+
+					installBtn->setText("Installing...");
+					QCoreApplication::processEvents();
+				}
+
+				QProcess installProc;
+				installProc.start("pkg", QStringList() << "install" << "-y" << cachedPlugins[i].pkgName);
+				installProc.waitForFinished();
+
+				if (installProc.exitCode() == 0) {
+					QProcess fileProc;
+					fileProc.start("dpkg", QStringList() << "-L" << cachedPlugins[i].pkgName);
+					fileProc.waitForFinished();
+					for (const QString& f : QString(fileProc.readAllStandardOutput()).split('\n')) {
+						if (f.endsWith(".so")) {
+							QString modName = f.mid(f.lastIndexOf('/') + 1);
+							modName.replace(".so", "");
+							cachedPlugins[i].moduleName = modName;
+							break;
+						}
+					}
+
+					cachedPlugins[i].isInstalled = true;
+					forceRestart_ = true;
+					saveCache();
+					reloadUI();
+				} else {
+					QString errorLog = installProc.readAllStandardError();
+					QMessageBox::critical(this, "Installation Failed", "Termux APT Error:\n\n" + errorLog);
+					installBtn->setText("Error");
+					installBtn->setStyleSheet("background-color: rgba(200, 50, 50, 0.3); color: #f44; font-weight: bold; border-radius: 4px;");
+					installBtn->setEnabled(true);
+				}
+			});
+
+		} else {
+			int modIndex = -1;
+			for (int j = 0; j < static_cast<int>(modules_.size()); ++j) {
+				if (modules_[j].module_name == data.moduleName.toStdString()) {
+					modIndex = j;
+					break;
+				}
+			}
+
+			if (modIndex == -1 && !data.moduleName.isEmpty()) {
+				ModuleInfo newMod;
+				newMod.display_name = data.displayName.toStdString();
+				newMod.module_name = data.moduleName.toStdString();
+				newMod.enabled = true;
+				newMod.enabledAtLaunch = false;
+
+				modules_.push_back(newMod);
+				modIndex = static_cast<int>(modules_.size()) - 1;
+
+				ui->manageRestartLabel->setVisible(true);
+				ui->buttonBox->button(QDialogButtonBox::Apply)->setText("Apply & Restart");
+			}
+
+			bool isEnabled = (modIndex != -1) ? modules_[modIndex].enabled : false;
+			bool isEnabledAtLaunch = (modIndex != -1) ? modules_[modIndex].enabledAtLaunch : false;
+
+			if (data.hasUpdate) {
+				QPushButton *updateBtn = new QPushButton("Update");
+				updateBtn->setFixedSize(80, 32);
+				updateBtn->setStyleSheet("background-color: rgba(50, 200, 50, 0.3); color: #4f4; border: 1px solid #4f4; border-radius: 4px; font-weight: bold; margin-right: 10px;");
+				updateBtn->setAutoDefault(false);
+				suffixLayout->addWidget(updateBtn);
+
+				connect(updateBtn, &QPushButton::clicked, this, [this, updateBtn, i]() {
+					updateBtn->setText("Updating...");
+					updateBtn->setEnabled(false);
+					QCoreApplication::processEvents();
+
+					QProcess proc;
+					proc.start("pkg", QStringList() << "upgrade" << "-y" << cachedPlugins[i].pkgName);
+					proc.waitForFinished();
+
+					if (proc.exitCode() == 0) {
+						cachedPlugins[i].hasUpdate = false;
+						forceRestart_ = true;
+						saveCache();
+						ui->manageRestartLabel->setVisible(true);
+						ui->buttonBox->button(QDialogButtonBox::Apply)->setText("Apply & Restart");
+						reloadUI();
+					} else {
+						QString errorLog = proc.readAllStandardError();
+						QMessageBox::critical(this, "Update Failed", "Termux APT Error:\n\n" + errorLog);
+						updateBtn->setText("Error");
+						updateBtn->setStyleSheet("background-color: rgba(200, 50, 50, 0.3); color: #f44; font-weight: bold; border-radius: 4px;");
+						updateBtn->setEnabled(true);
+					}
+				});
+			}
+
+			idian::ToggleSwitch *stateToggle = new idian::ToggleSwitch(isEnabled);
+
+			QPushButton *uninstallBtn = new QPushButton("");
+			uninstallBtn->setFixedSize(36, 36);
+			uninstallBtn->setIcon(QIcon(QString(":/icons/") + (isEnabledAtLaunch ? "trash-grey.svg" : "trash-red.svg")));
+			uninstallBtn->setIconSize(QSize(22, 22));
+			uninstallBtn->setToolTip(isEnabledAtLaunch ? "Disable and apply changes to unlock uninstall" : "Uninstall plugin completely");
+			uninstallBtn->setEnabled(!isEnabledAtLaunch);
+			uninstallBtn->setAutoDefault(false);
+
+			if (isEnabledAtLaunch) {
+				uninstallBtn->setStyleSheet("background: transparent; border: none; opacity: 0.5;");
+			} else {
+				uninstallBtn->setStyleSheet("QPushButton { background: transparent; border: none; } QPushButton:hover { background-color: rgba(255, 0, 0, 0.1); border-radius: 4px; }");
+			}
+
+			suffixLayout->addWidget(stateToggle);
+			suffixLayout->addWidget(uninstallBtn);
+			suffixLayout->addWidget(detailsBtn);
+			mainRow->setSuffix(suffixContainer);
+
+			manageList->addRow(mainRow);
+			manageList->addRow(detailsRow);
+
+			connect(stateToggle, &idian::ToggleSwitch::toggled, this, [this, modIndex](bool checked) {
+				if (modIndex != -1) {
+					modules_[modIndex].enabled = checked;
+					bool requiresRestart = false;
+					for (auto &m : modules_) {
+						if (m.enabledAtLaunch != m.enabled) { requiresRestart = true; break; }
+					}
+					if (modules_.size() != original_modules_.size()) requiresRestart = true;
+
+					ui->manageRestartLabel->setVisible(requiresRestart);
+					ui->buttonBox->button(QDialogButtonBox::Apply)->setText(requiresRestart ? "Apply & Restart" : "Apply Changes");
+				}
+			});
+
+			connect(uninstallBtn, &QPushButton::clicked, this, [this, uninstallBtn, i]() {
+				uninstallBtn->setEnabled(false);
+				QCoreApplication::processEvents();
+
+				QProcess proc;
+				proc.start("pkg", QStringList() << "remove" << "-y" << cachedPlugins[i].pkgName);
+				proc.waitForFinished();
+
+				if (proc.exitCode() == 0) {
+					cachedPlugins[i].isInstalled = false;
+					cachedPlugins[i].moduleName = "";
+					forceRestart_ = true;
+					saveCache();
+					reloadUI();
+				} else {
+					QString errorLog = proc.readAllStandardError();
+					QMessageBox::critical(this, "Uninstall Failed", "Termux APT Error:\n\n" + errorLog);
+					uninstallBtn->setEnabled(true);
+				}
+			});
+		}
+
+		allUiRows.append(PluginUI{mainRow, (data.displayName + " " + data.pkgName + " " + data.shortDesc).toLower()});
+
+		connect(detailsBtn, &QPushButton::clicked, this, [detailsBtn, detailsRow]() {
+			bool isNowVisible = !detailsRow->isVisible();
+			detailsRow->setVisible(isNowVisible);
+			detailsBtn->setIcon(QIcon(QString(":/icons/") + (isNowVisible ? "chevron-up.svg" : "chevron-down.svg")));
+		});
+	}
+
+	emit ui->searchBox->textChanged(ui->searchBox->text());
+}
+
+QString PluginManagerWindow::getCacheFilePath() const {
+	QString configDir = QDir::homePath() + "/.config/obs-studio/plugin_manager";
+	QDir().mkpath(configDir);
+	return configDir + "/apt_cache.json";
+}
+
+void PluginManagerWindow::saveCache() {
+	QJsonArray array;
+	for (const auto& p : cachedPlugins) {
+		QJsonObject obj;
+		obj["pkgName"] = p.pkgName;
+		obj["displayName"] = p.displayName;
+		obj["shortDesc"] = p.shortDesc;
+		obj["fullText"] = p.fullText;
+		obj["version"] = p.version;
+		obj["downloadSize"] = p.downloadSize;
+		obj["installedSize"] = p.installedSize;
+		obj["homepage"] = p.homepage;
+		obj["isInstalled"] = p.isInstalled;
+		obj["hasUpdate"] = p.hasUpdate;
+		obj["moduleName"] = p.moduleName;
+		array.append(obj);
+	}
+
+	QJsonDocument doc(array);
+	QFile file(getCacheFilePath());
+	if (file.open(QIODevice::WriteOnly)) {
+		file.write(doc.toJson());
+	}
+}
+
+bool PluginManagerWindow::loadCache() {
+	QFile file(getCacheFilePath());
+	if (!file.open(QIODevice::ReadOnly)) return false;
+
+	QJsonDocument doc = QJsonDocument::fromJson(file.readAll());
+	if (!doc.isArray()) return false;
+
+	QJsonArray array = doc.array();
+	cachedPlugins.clear();
+
+	for (int i = 0; i < array.size(); ++i) {
+		QJsonObject obj = array[i].toObject();
+		FetchedPluginData data;
+		data.pkgName = obj["pkgName"].toString();
+		data.displayName = obj["displayName"].toString();
+		data.shortDesc = obj["shortDesc"].toString();
+		data.fullText = obj["fullText"].toString();
+		data.version = obj["version"].toString();
+		data.downloadSize = obj["downloadSize"].toString();
+		data.installedSize = obj["installedSize"].toString();
+		data.homepage = obj["homepage"].toString();
+		data.isInstalled = obj["isInstalled"].toBool();
+		data.hasUpdate = obj["hasUpdate"].toBool();
+		data.moduleName = obj["moduleName"].toString();
+
+		cachedPlugins.append(data);
+	}
+
+	return !cachedPlugins.isEmpty();
+}
+
+}; // namespace OBS
