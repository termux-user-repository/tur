+// --- CUSTOM DETAILS ROW ---
+// Bypasses idian::Row's restricted column layout to allow 100% width wrapping
+// and implements the "Inner Well" styling for the expanded chevron section.
+class DetailsRow : public idian::GenericRow {
+public:
+	QLabel *contentLabel;
+
+	DetailsRow(QWidget *parent = nullptr) : GenericRow(parent) {
+		QVBoxLayout *layout = new QVBoxLayout(this);
+		layout->setContentsMargins(15, 12, 15, 15);
+
+		contentLabel = new QLabel(this);
+		contentLabel->setWordWrap(true);
+		contentLabel->setTextFormat(Qt::RichText);
+		contentLabel->setOpenExternalLinks(true);
+
+		layout->addWidget(contentLabel);
+
+		setStyleSheet(
+			"DetailsRow { background-color: rgba(0, 0, 0, 0.2); border-top: 1px solid #333; border-bottom: 1px solid #222; }"
+			"QLabel { background: transparent; border: none; }"
+		);
+	}
+
+	void setTitle(const QString &) override {}
+	void setDescription(const QString &) override {}
+};
+// --------------------------
+
+PluginManagerWindow::PluginManagerWindow(const std::vector<ModuleInfo> &modules, QWidget *parent)
+	: QDialog(parent),
+	  modules_(modules),
+	  original_modules_(modules),
+	  ui(new Ui::PluginManagerWindow)
+{
+	setWindowFlags(windowFlags() & ~Qt::WindowContextHelpButtonHint);
+	ui->setupUi(this);
+
+	ui->searchBox->setStyleSheet("padding: 8px; border: 1px solid #444; border-radius: 4px; background-color: rgba(0,0,0,0.2); font-size: 11pt; color: white;");
+	ui->tabs->setStyleSheet("QTabBar::tab { padding: 8px 30px; font-size: 11pt; font-weight: bold; }");
+	ui->manageRestartLabel->setVisible(false);
+	ui->manageRestartLabel->setStyleSheet("color: #ffaa00; font-weight: bold; font-size: 11pt;");
+
+	QPushButton *applyBtn = ui->buttonBox->button(QDialogButtonBox::Apply);
+	QPushButton *cancelBtn = ui->buttonBox->button(QDialogButtonBox::Cancel);
+
+	applyBtn->setAutoDefault(false);
+	cancelBtn->setAutoDefault(false);
+	ui->refreshBtn->setAutoDefault(false);
+
+	applyBtn->setStyleSheet("background-color: #2b2b2b; color: white; border: 1px solid #555; padding: 6px 15px; border-radius: 4px; font-weight: bold;");
+	cancelBtn->setStyleSheet("padding: 6px 15px; border-radius: 4px;");
+
+	connect(applyBtn, &QPushButton::clicked, this, &PluginManagerWindow::onApplyClicked);
+	connect(cancelBtn, &QPushButton::clicked, this, &PluginManagerWindow::onCancelClicked);
+
+	ui->refreshBtn->setText("");
+	ui->refreshBtn->setIcon(QIcon(":/icons/refresh.svg"));
+	ui->refreshBtn->setIconSize(QSize(24, 24));
+	ui->refreshBtn->setStyleSheet("QPushButton { border: none; background: transparent; } QPushButton:hover { background-color: rgba(255,255,255,0.1); border-radius: 4px; }");
+
+	storeList = new idian::PropertiesList(this);
+	manageList = new idian::PropertiesList(this);
+
+	ui->storeScroll->setHorizontalScrollBarPolicy(Qt::ScrollBarAlwaysOff);
+	ui->manageScroll->setHorizontalScrollBarPolicy(Qt::ScrollBarAlwaysOff);
+
+	ui->storeScroll->setWidgetResizable(true);
+	ui->manageScroll->setWidgetResizable(true);
+	ui->storeLayout->addWidget(storeList);
+	ui->manageLayout->addWidget(manageList);
+	ui->storeLayout->addStretch();
+	ui->manageLayout->addStretch();
+
+	storeEmptyLabel = new QLabel("Initializing cache...", this);
+	manageEmptyLabel = new QLabel("Initializing cache...", this);
+	storeEmptyLabel->setStyleSheet("color: #888; font-size: 12pt; margin-top: 20px;");
+	manageEmptyLabel->setStyleSheet("color: #888; font-size: 12pt; margin-top: 20px;");
+	storeEmptyLabel->setAlignment(Qt::AlignCenter);
+	manageEmptyLabel->setAlignment(Qt::AlignCenter);
+	ui->storeLayout->addWidget(storeEmptyLabel);
+	ui->manageLayout->addWidget(manageEmptyLabel);
+
+	connect(ui->searchBox, &QLineEdit::textChanged, this, [this](const QString &text) {
+		QString query = text.toLower();
+		int storeVis = 0, manageVis = 0;
+
+		for (const auto &item : allUiRows) {
+			bool match = query.isEmpty() || item.searchString.contains(query);
+			item.row->setVisible(match);
+			if (match) {
+				if (storeList->isAncestorOf(item.row)) storeVis++;
+				if (manageList->isAncestorOf(item.row)) manageVis++;
+			}
+		}
+
+		if (!cachedPlugins.isEmpty()) {
+			storeEmptyLabel->setText(query.isEmpty() ? "No new plugins available." : "No plugins match your search.");
+			manageEmptyLabel->setText(query.isEmpty() ? "No plugins installed yet." : "No installed plugins match your search.");
+		}
+
+		storeEmptyLabel->setVisible(storeVis == 0);
+		manageEmptyLabel->setVisible(manageVis == 0);
+	});
+
+	connect(ui->refreshBtn, &QPushButton::clicked, this, [this]() {
+		ui->refreshBtn->setEnabled(false);
+		ui->searchBox->setEnabled(false);
+
+		storeEmptyLabel->setText("Updating repository... UI will freeze momentarily.");
+		manageEmptyLabel->setText("Updating repository... UI will freeze momentarily.");
+		storeEmptyLabel->setVisible(true);
+		manageEmptyLabel->setVisible(true);
+
+		QCoreApplication::processEvents();
+
+		QProcess proc(this);
+		proc.start("pkg", QStringList() << "update");
+		proc.waitForFinished();
+
+		populatePlugins();
+		saveCache();
+		reloadUI();
+
+		ui->refreshBtn->setEnabled(true);
+		ui->searchBox->setEnabled(true);
+	});
+
+	if (loadCache()) {
+		reloadUI();
+	} else {
+		QTimer::singleShot(50, this, [this]() {
+			populatePlugins();
+			saveCache();
+			reloadUI();
+		});
+	}
+}
