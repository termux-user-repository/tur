From 4e76ae9bbe6e75185c4b815b5336d16bb1ababaf Mon Sep 17 00:00:00 2001
From: lumaparallax <257510328+lumaparallax@users.noreply.github.com>
Date: Thu, 26 Mar 2026 21:35:42 +0900
Subject: [PATCH 06/16] build: Disable Libpci dependency in obs-ffmpeg for
 Termux

- plugins/obs-ffmpeg/cmake/dependencies.cmake: Removed the strict
  requirement for Libpci on Linux environments. Android/Termux runs in
  a restricted user-space where SELinux blocks PCI bus scanning, making
  libpci unnecessary and preventing successful CMake generation.
---
 plugins/obs-ffmpeg/cmake/dependencies.cmake | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/plugins/obs-ffmpeg/cmake/dependencies.cmake b/plugins/obs-ffmpeg/cmake/dependencies.cmake
index 5e523cd37..31aa1933a 100644
--- a/plugins/obs-ffmpeg/cmake/dependencies.cmake
+++ b/plugins/obs-ffmpeg/cmake/dependencies.cmake
@@ -17,8 +17,10 @@ if(OS_WINDOWS AND CMAKE_VS_PLATFORM_NAME STREQUAL x64)
   add_subdirectory(obs-amf-test)
 elseif(OS_LINUX OR OS_FREEBSD OR OS_OPENBSD)
   find_package(Libva REQUIRED)
-  find_package(Libpci REQUIRED)
   find_package(Libdrm REQUIRED)
+  if(NOT OS_ANDROID)
+     find_package(Libpci REQUIRED)
+  endif()
 endif()
 
 if(ENABLE_NEW_MPEGTS_OUTPUT)
-- 
2.53.0

