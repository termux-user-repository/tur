diff --git a/plugins/obs-mediacodec/CMakeLists.txt b/plugins/obs-mediacodec/CMakeLists.txt
new file mode 100644
index 000000000..2285fa060
--- /dev/null
+++ b/plugins/obs-mediacodec/CMakeLists.txt
@@ -0,0 +1,36 @@
+cmake_minimum_required(VERSION 3.28...3.30)
+
+option(ENABLE_MEDIACODEC "Build Android MediaCodec Hardware Encoder Plugin" ON)
+
+if(NOT ENABLE_MEDIACODEC)
+  target_disable_feature(obs-mediacodec "Android MediaCodec Hardware Encoder")
+  target_disable(obs-mediacodec)
+  return()
+endif()
+
+# Force Termux/Clang to target API 26 so AMediaCodec_createInputSurface resolves
+add_compile_options(-target aarch64-linux-android26)
+add_link_options(-target aarch64-linux-android26)
+
+add_library(obs-mediacodec MODULE)
+add_library(OBS::mediacodec ALIAS obs-mediacodec)
+
+target_sources(
+  obs-mediacodec
+  PRIVATE
+    obs-mediacodec.c
+    mediacodec-h264.c
+    mediacodec-hevc.c
+)
+
+target_link_libraries(
+  obs-mediacodec
+  PRIVATE
+    OBS::libobs
+    android
+    EGL
+    GLESv2
+    mediandk
+)
+
+set_target_properties_obs(obs-mediacodec PROPERTIES FOLDER plugins/obs-mediacodec PREFIX "")
